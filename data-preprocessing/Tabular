:"ok","timestamp":1781615888846,"user_tz":-540,"elapsed":185023,"user":{"displayName":"Shinwoo Noh","userId":"07027261604986966181"}},"outputId":"177de6df-a03b-48fd-b9f4-c235fb07bef6"},"source":["import os\n","import geopandas as gpd\n","import pandas as pd\n","import numpy as np\n","from shapely.geometry import Point\n","\n","# Define clean paths\n","RAW_DATA_PATH = os.path.join(PROJECT_ROOT, 'data/raw')\n","INTERIM_DATA_PATH = os.path.join(PROJECT_ROOT, 'data/interim')\n","TARGET_CRS = \"EPSG:32198\"\n","\n","def load_and_project(name, path):\n","    print(f\"Loading {name}...\")\n","    gdf = gpd.read_file(path)\n","    if gdf.crs != TARGET_CRS:\n","        print(f\"  Reprojecting {name} from {gdf.crs} to {TARGET_CRS}\")\n","        gdf = gdf.to_crs(TARGET_CRS)\n","    return gdf\n","\n","# Core geological layers\n","paths = {\n","    'lithology': os.path.join(RAW_DATA_PATH, 'tabular/SIGEOM_QC_Geologie_du_socle_SHP/GEOL_SIGEOM_QC.SHP/Zone geologique.shp'),\n","    'faults': os.path.join(RAW_DATA_PATH, 'tabular/SIGEOM_QC_Geologie_du_socle_SHP/GEOL_SIGEOM_QC.SHP/Faille generale.shp'),\n","    'contacts': os.path.join(RAW_DATA_PATH, 'tabular/SIGEOM_QC_Geologie_du_socle_SHP/GEOL_SIGEOM_QC.SHP/Contact geologique.shp')\n","}\n","\n","# Combined Rock Occurrences (North + South)\n","occ_north_path = os.path.join(RAW_DATA_PATH, 'tabular/GEOCH_SIGEOM_QC.SHP/Echantillon roche nord.shp')\n","occ_south_path = os.path.join(RAW_DATA_PATH, 'tabular/GEOCH_SIGEOM_QC.SHP/Echantillon roche sud.shp')\n","\n","# Load primary layers\n","gdf_lith = load_and_project('Lithology', paths['lithology'])\n","gdf_faults = load_and_project('Faults', paths['faults'])\n","gdf_cont = load_and_project('Contacts', paths['contacts'])\n","\n","# Load and merge occurrences\n","gdf_occ_n = load_and_project('Occurrences North', occ_north_path)\n","gdf_occ_s = load_and_project('Occurrences South', occ_south_path)\n","gdf_occ = pd.concat([gdf_occ_n, gdf_occ_s], ignore_index=True)\n","gdf_occ = gpd.GeoDataFrame(gdf_occ, crs=TARGET_CRS)\n","\n","# Helper coordinates\n","gdf_occ['Easting'] = gdf_occ.geometry.x\n","gdf_occ['Northing'] = gdf_occ.geometry.y\n","\n","print(f\"\\nInitialization Complete.\")\n","print(f\"Total Samples: {len(gdf_occ):,}\")"],"execution_count":3,"outputs":[{"output_type":"stream","name":"stdout","text":["Loading Lithology...\n","  Reprojecting Lithology from EPSG:4269 to EPSG:32198\n","Loading Faults...\n","  Reprojecting Faults from EPSG:4269 to EPSG:32198\n","Loading Contacts...\n","  Reprojecting Contacts from EPSG:4269 to EPSG:32198\n","Loading Occurrences North...\n","  Reprojecting Occurrences North from EPSG:4269 to EPSG:32198\n","Loading Occurrences South...\n","  Reprojecting Occurrences South from EPSG:4269 to EPSG:32198\n","\n","Initialization Complete.\n","Total Samples: 582,192\n"]}]},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/","height":658},"id":"52d8a9cd","executionInfo":{"status":"ok","timestamp":1781616095451,"user_tz":-540,"elapsed":1942,"user":{"displayName":"Shinwoo Noh","userId":"07027261604986966181"}},"outputId":"27889ca5-911b-4364-cc03-90be6f115deb"},"source":["import matplotlib.pyplot as plt\n","\n","# Visualization: Spatial Distribution of the Unified Dataset\n","# This now includes all 582,192 samples across the entire province\n","plt.figure(figsize=(12, 10))\n","plt.scatter(gdf_occ['Easting'], gdf_occ['Northing'], s=0.05, alpha=0.05, color='teal')\n","\n","plt.title(\"Spatial Distribution of Combined Rock Samples (Full Quebec - EPSG:32198)\")\n","plt.xlabel(\"Easting (m)\")\n","plt.ylabel(\"Northing (m)\")\n","plt.grid(True, linestyle='--', alpha=0.3)\n","\n","# Adding a text annotation to confirm the sample size on the plot\n","plt.text(gdf_occ['Easting'].min(), gdf_occ['Northing'].max(), f\"Total Samples: {len(gdf_occ):,}\",\n","         fontsize=12, bbox=dict(facecolor='white', alpha=0.5))\n","\n","plt.show()"],"execution_count":4,"outputs":[{"output_type":"display_data","data":{"