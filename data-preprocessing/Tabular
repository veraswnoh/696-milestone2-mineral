clean_strat(name):\n","    if pd.isna(name): return 'UNKNOWN'\n","    # Remove regional tags in brackets like [narc] or [marc]\n","    return re.sub(r'\\[.*?\\]', '', str(name)).strip()\n","\n","# 2. Overwrite the columns with their cleaned string versions\n","gdf_lith['CODE_LITH'] = gdf_lith['CODE_LITH'].apply(parse_lith_root)\n","gdf_lith['STRAT'] = gdf_lith['STRAT'].apply(clean_strat)\n","\n","# 3. Remove any old encoding columns to keep the dataframe clean\n","cols_to_drop = ['CODE_LITH_encoded', 'STRAT_encoded', 'CODE_LITH_root', 'STRAT_clean', 'CODE_LITH_grouped']\n","gdf_lith = gdf_lith.drop(columns=[c for c in cols_to_drop if c in gdf_lith.columns])\n","\n","print(f\"Cleaning complete. Columns retained: CODE_LITH, STRAT\")\n","display(gdf_lith[['CODE_LITH', 'STRAT']].head())"],"execution_count":8,"outputs":[{"output_type":"stream","name":"stdout","text":["Cleaning complete. Columns retained: CODE_LITH, STRAT\n"]},{"output_type":"display_data","data":{"text/plain":["  CODE_LITH  STRAT\n","0     M4-S9   qlp2\n","1       I1B  deb1b\n","2       I1C    rfe\n","3       I1B    duy\n","4       I1B    duy"],"text/html":["\n","  <div id=\"df-1d90b1a0-6eb4-4eed-ab56-b0c86e1181a9\" class=\"colab-df-container\">\n","    <div>\n","<style scoped>\n","    .dataframe tbody tr th:only-of-type {\n","        vertical-align: middle;\n","    }\n","\n","    .dataframe tbody tr th {\n","        vertical-align: top;\n","    }\n","\n","    .dataframe thead th {\n","        text-align: right;\n","    }\n","</style>\n","<table border=\"1\" class=\"dataframe\">\n","  <thead>\n","    <tr style=\"text-align: right;\">\n","      <th></th>\n","      <th>CODE_LITH</th>\n","      <th>STRAT</th>\n","    </tr>\n","  </thead>\n","  <tbody>\n","    <tr>\n","      <th>0</th>\n","      <td>M4-S9</td>\n","      <td>qlp2</td>\n","    </tr>\n","    <tr>\n","      <th>1</th>\n","      <td>I1B</td>\n","      <td>deb1b</td>\n","    </tr>\n","    <tr>\n","      <th>2</th>\n","      <td>I1C</td>\n","      